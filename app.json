{
  "expo": {
    "name": "Sevenhood",
    "slug": "sevenhood-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0D2818"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sevenhood.resident",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D2818"
      },
      "package": "com.sevenhood.resident"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Sevenhood to use Face ID for sign-in"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C9A56B",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Sevenhood"
        }
      ]
    ],
    "scheme": "sevenhood",
    "experiments": {
      "typedRoutes": true
    }
  }
}
